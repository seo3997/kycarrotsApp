<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Order Basic Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/tv_order_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="결제완료"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorPrimary"/>
                    <TextView
                        android:id="@+id/tv_order_no"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="주문번호: ORDER-000"
                        android:layout_marginTop="4dp"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tv_order_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="주문일시: 2024-03-04 12:00"
                        android:textSize="13sp"
                        android:textColor="#666666"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Management Actions Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📦 관리가능 처리"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>
                    
                    <Button
                        android:id="@+id/btn_confirm_deposit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="입금 확인 (배송시작가능)"
                        android:backgroundTint="#4F46E5"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp"/>

                    <Button
                        android:id="@+id/btn_branch_confirm_deposit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="본사 입금 확인 요청"
                        android:backgroundTint="#8B5CF6"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:id="@+id/ll_shipping_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">
                        
                        <Spinner
                            android:id="@+id/sp_carrier"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_spinner"
                            android:layout_marginBottom="8dp"/>
                        
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_tracking_no"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="운송장 번호"
                                android:inputType="number"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <Button
                            android:id="@+id/btn_update_shipping"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="배송 정보 업데이트"
                            android:backgroundTint="#10B981"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_confirm_delivery"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="배송 완료 처리"
                        android:backgroundTint="#F59E0B"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp"/>

                    <Button
                        android:id="@+id/btn_confirm_order"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="주문 확정 처리"
                        android:backgroundTint="#6366F1"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp"/>

                    <Button
                        android:id="@+id/btn_cancel_order"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="주문 취소"
                        android:backgroundTint="#EF4444"
                        android:visibility="gone"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Customer & Shipping Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋 주문 및 배송 정보"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>
                    
                    <TextView
                        android:id="@+id/tv_buyer_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="주문자: 홍길동 (010-1234-5678)"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/tv_address"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="주소: (12345) 서울시 강남구..."
                        android:layout_marginTop="8dp"
                        android:textSize="14sp"/>

                     <TextView
                        android:id="@+id/tv_memo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="배송메모: 문 앞"
                        android:layout_marginTop="8dp"
                        android:textSize="14sp"
                        android:textColor="#888888"/>

                     <TextView
                        android:id="@+id/tv_carrier_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="배송사: 미정"
                        android:layout_marginTop="8dp"
                        android:textSize="14sp"
                        android:textColor="#4F46E5"
                        android:textStyle="bold"
                        android:visibility="gone"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Product Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true"
                android:layout_marginBottom="80dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📦 상품 목록"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>
                    
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_items"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/ll_progress_circle"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#99FFFFFF"
        android:visibility="gone"
        android:elevation="10dp">
        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminate="true"/>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
